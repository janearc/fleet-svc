#!/usr/bin/env bash
set -euo pipefail

echo "=== pre-push: enforcing 80% coverage floor ==="

# Run tests with coverage
uv run pytest tests/ --cov=fleet --cov-report=term --cov-fail-under=80

if [ $? -ne 0 ]; then
    echo "BLOCKED: coverage is below 80%. Push rejected."
    exit 1
fi

echo "=== pre-push: coverage gate passed ==="
